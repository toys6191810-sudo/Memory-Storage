<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Memory_Storage"
    x:Class="Memory_Storage.ActivityPage"
    Shell.NavBarIsVisible="False"
    x:Name="RootPage"
    BackgroundColor="#F7F8FA">

    <Grid x:Name="RootGrid" ColumnDefinitions="260,*" RowDefinitions="Auto,*">
        <Border
            x:Name="SidebarBorder"
            Grid.RowSpan="2"
            Padding="20"
            BackgroundColor="White"
            Stroke="#E1E6EC"
            StrokeThickness="1">
            <ScrollView>
                <VerticalStackLayout x:Name="SidebarStack" Spacing="18">
                    <Button
                        x:Name="BackButton"
                        Text="Back"
                        Padding="16,10"
                        HorizontalOptions="Fill"
                        BackgroundColor="#1E8E5A"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        Clicked="BackButton_Clicked" />

                    <VerticalStackLayout x:Name="SidebarHeader" Spacing="2">
                        <Label x:Name="FunctionsLabel" Text="Functions" FontSize="20" FontAttributes="Bold" TextColor="#14171A" />
                        <Label x:Name="SidePanelLabel" Text="Side panel" FontSize="13" TextColor="#6B7785" />
                    </VerticalStackLayout>

                    <Button x:Name="OpenedProgramsButton" Text="Record opened programs" StyleId="UsedApps" HeightRequest="44" Clicked="FeatureButton_Clicked" BackgroundColor="#EAF5EF" TextColor="#0F7B4D" CornerRadius="12" />
                    <Button x:Name="DurationButton" Text="Record activity duration" StyleId="Duration" HeightRequest="44" Clicked="FeatureButton_Clicked" BackgroundColor="#EAF5EF" TextColor="#0F7B4D" CornerRadius="12" />
                    <Button x:Name="TimelineButton" Text="Timeline view" StyleId="Timeline" HeightRequest="44" Clicked="FeatureButton_Clicked" BackgroundColor="#EAF5EF" TextColor="#0F7B4D" CornerRadius="12" />
                    <Button x:Name="SearchFeatureButton" Text="Search function" StyleId="Search" HeightRequest="44" Clicked="FeatureButton_Clicked" BackgroundColor="#EAF5EF" TextColor="#0F7B4D" CornerRadius="12" />

                    <Border
                        x:Name="RecordingToggleCard"
                        Margin="0,8,0,0"
                        Padding="16,14"
                        BackgroundColor="#111816"
                        Stroke="#263A33"
                        StrokeThickness="1.5"
                        HorizontalOptions="Fill">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#80000000" Offset="0,10" Radius="20" Opacity="0.35" />
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10" HorizontalOptions="Center">
                            <Label
                                x:Name="RecordingToggleLabel"
                                Text="開啟/關閉記憶資料的記錄行為"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="White"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center"
                                LineBreakMode="NoWrap"
                                MaxLines="1"
                                VerticalTextAlignment="Center" />
                            <Border
                                x:Name="RecordingToggleButton"
                                Grid.Row="2"
                                WidthRequest="84"
                                HeightRequest="38"
                                BackgroundColor="#20C978"
                                StrokeThickness="0"
                                HorizontalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="19" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="RecordingToggleButton_Tapped" />
                                </Border.GestureRecognizers>
                                <Grid Padding="4.5">
                                    <Border
                                        x:Name="RecordingToggleThumb"
                                        WidthRequest="29"
                                        HeightRequest="29"
                                        BackgroundColor="White"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Center"
                                        StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14.5" />
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="#66000000" Offset="0,3" Radius="7" Opacity="0.35" />
                                        </Border.Shadow>
                                    </Border>
                                </Grid>
                            </Border>
                            <Label
                                x:Name="RecordingToggleStateLabel"
                                Grid.Row="1"
                                Text="Recording ON"
                                FontSize="11"
                                FontAttributes="Bold"
                                TextColor="#6FE0A5"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center" />
                        </Grid>
                    </Border>

                    <VerticalStackLayout Spacing="10" Margin="0,2,0,0">
                        <Button
                            x:Name="AppUserGuideButton"
                            Text="App User Guide"
                            HeightRequest="44"
                            Padding="12,8"
                            BackgroundColor="#C9362B"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            Clicked="AppUserGuideButton_Clicked" />
                        <Button
                            x:Name="PrivacyStatementButton"
                            Text="Privacy Statement"
                            HeightRequest="44"
                            Padding="12,8"
                            BackgroundColor="#C9362B"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            Clicked="PrivacyStatementButton_Clicked" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <Grid
            Grid.Column="1"
            Padding="32,24,32,12"
            ColumnDefinitions="*,Auto,Auto,Auto,Auto"
            RowDefinitions="Auto,Auto,Auto"
            ColumnSpacing="12"
            RowSpacing="14">
            <VerticalStackLayout Spacing="2">
                <Label x:Name="TitleLabel" Text="Memory Storage" FontSize="32" FontAttributes="Bold" TextColor="#14171A" />
                <Label x:Name="TodayLabel" Text="{Binding TodayTitle}" FontSize="15" TextColor="#5F6B7A" />
            </VerticalStackLayout>

            <Button x:Name="LoginButton" Grid.Column="1" Text="Login" WidthRequest="86" HeightRequest="42" BackgroundColor="#1E8E5A" TextColor="White" CornerRadius="8" Clicked="LoginButton_Clicked" />
            <Button x:Name="RegisterButton" Grid.Column="2" Text="Register" WidthRequest="86" HeightRequest="42" BackgroundColor="#1E8E5A" TextColor="White" CornerRadius="8" Clicked="RegisterButton_Clicked" />
            <Border
                x:Name="AvatarButton"
                Grid.Column="3"
                WidthRequest="48"
                HeightRequest="42"
                BackgroundColor="#EAF5EF"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="21" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="AvatarButton_Clicked" />
                </Border.GestureRecognizers>
                <Grid>
                    <Image
                        x:Name="AvatarImage"
                        Aspect="AspectFill"
                        IsVisible="False" />
                    <local:AvatarIconView
                        x:Name="AvatarIcon"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Grid>
            </Border>
            <Border
                x:Name="SettingsButton"
                Grid.Column="4"
                WidthRequest="48"
                HeightRequest="42"
                BackgroundColor="#EAF5EF"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="21" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="SettingsButton_Clicked" />
                </Border.GestureRecognizers>
                <local:SettingsIconView
                    x:Name="SettingsIcon"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Border>

            <SearchBar
                Grid.Row="1"
                Grid.ColumnSpan="5"
                x:Name="RecordSearchBar"
                Placeholder="Search app, project, file, note, or cabinet code"
                SearchButtonPressed="RecordSearchBar_SearchButtonPressed"
                TextChanged="RecordSearchBar_TextChanged" />

            <Border
                x:Name="FeaturePanel"
                Grid.Row="2"
                Grid.ColumnSpan="5"
                Padding="0"
                BackgroundColor="White"
                Stroke="#E1E6EC"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto">
                    <Grid Padding="14,12" ColumnDefinitions="*,Auto">
                        <Label x:Name="FeatureTitleLabel" Text="{Binding CurrentFeatureTitle}" FontSize="16" FontAttributes="Bold" TextColor="#14171A" VerticalTextAlignment="Center" />
                        <Button
                            x:Name="FeatureExpandButton"
                            Grid.Column="1"
                            Text="⌄"
                            WidthRequest="36"
                            HeightRequest="32"
                            Padding="0"
                            BackgroundColor="#EAF5EF"
                            TextColor="#0F7B4D"
                            FontAttributes="Bold"
                            CornerRadius="16"
                            Clicked="FeatureExpandButton_Clicked" />
                    </Grid>

                    <ScrollView
                        x:Name="FeatureContentScroll"
                        Grid.Row="1"
                        Padding="14,0,14,12"
                        MaximumHeightRequest="150"
                        Orientation="Vertical">
                        <Label x:Name="FeatureContentLabel" Text="{Binding CurrentFeatureContent}" FontSize="13" TextColor="#3C4653" />
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>

        <CollectionView
            x:Name="RecordCollectionView"
            Grid.Row="1"
            Grid.Column="1"
            Margin="32,96,32,24"
            ItemsSource="{Binding VisibleRecords}"
            SelectionMode="Single"
            SelectionChanged="RecordCollectionView_SelectionChanged">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="4" HorizontalItemSpacing="18" VerticalItemSpacing="18" />
            </CollectionView.ItemsLayout>
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label x:Name="NoRecordsLabel" Text="No records yet" FontSize="18" TextColor="#3C4653" HorizontalTextAlignment="Center" />
                    <Label x:Name="FreshSessionLabel" Text="This session starts fresh and clears automatically when the app closes." FontSize="14" TextColor="#6B7785" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border WidthRequest="230" HeightRequest="258" Padding="12" BackgroundColor="White" Stroke="#D9E1E8" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid HeightRequest="234">
                            <Grid RowDefinitions="Auto,132,Auto" RowSpacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Border Padding="8,5" BackgroundColor="#26343B" Stroke="#26343B" StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding DateBadge}" FontSize="12" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                                </Border>
                                <Border Grid.Column="1" Margin="8,0,0,0" WidthRequest="38" HeightRequest="38" BackgroundColor="#FFFFFF" Stroke="#26343B" StrokeThickness="2">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="19" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding CabinetCode}" FontSize="12" FontAttributes="Bold" TextColor="#26343B" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Border WidthRequest="116" HeightRequest="128" HorizontalOptions="Center" VerticalOptions="Center" BackgroundColor="#F9FAFB" Stroke="#333740" StrokeThickness="5">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Grid Padding="14" RowDefinitions="*,*,*" RowSpacing="8">
                                        <Border BackgroundColor="White" Stroke="#333740" StrokeThickness="4">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="3" /></Border.StrokeShape>
                                            <BoxView HeightRequest="4" WidthRequest="44" Color="#333740" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <Border Grid.Row="1" BackgroundColor="White" Stroke="#333740" StrokeThickness="4">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="3" /></Border.StrokeShape>
                                            <BoxView HeightRequest="4" WidthRequest="44" Color="#333740" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <Border Grid.Row="2" BackgroundColor="White" Stroke="#333740" StrokeThickness="4">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="3" /></Border.StrokeShape>
                                            <BoxView HeightRequest="4" WidthRequest="44" Color="#333740" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border WidthRequest="78" HeightRequest="86" Margin="112,42,0,0" HorizontalOptions="Center" VerticalOptions="Center" BackgroundColor="#FFFFFF" Stroke="#333740" StrokeThickness="5">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4" />
                                    </Border.StrokeShape>
                                    <Grid RowDefinitions="18,*" Padding="10">
                                        <BoxView HeightRequest="5" WidthRequest="24" Color="#333740" HorizontalOptions="Start" VerticalOptions="Center" />
                                        <BoxView Grid.Row="1" WidthRequest="5" HeightRequest="34" Color="#333740" HorizontalOptions="Start" VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </Grid>

                                <Label Grid.Row="2" Text="{Binding FileTitle}" FontSize="15" FontAttributes="Bold" TextColor="#14171A" HorizontalTextAlignment="Center" />
                            </Grid>
                            <Border
                                WidthRequest="22"
                                HeightRequest="22"
                                Margin="0,0,-11,-11"
                                BackgroundColor="Transparent"
                                Stroke="#1E8E5A"
                                StrokeThickness="1.5"
                                HorizontalOptions="End"
                                VerticalOptions="End"
                                IsVisible="{Binding Source={x:Reference RootPage}, Path=BindingContext.IsDeleteMode}"
                                ZIndex="5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="5" />
                                </Border.StrokeShape>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelectedForDeletion}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#1E8E5A" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label
                                    Text="✓"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="White"
                                    ScaleX="1.15"
                                    HorizontalTextAlignment="Center"
                                    VerticalTextAlignment="Center"
                                    Opacity="0">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsSelectedForDeletion}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid
            x:Name="DeleteToolbar"
            Grid.Row="1"
            Grid.Column="1"
            Margin="32,46,32,0"
            HeightRequest="40"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="18"
            VerticalOptions="Start">
            <HorizontalStackLayout
                x:Name="DeleteLinksPanel"
                Spacing="20"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsVisible="{Binding IsDeleteMode}">
                <Label
                    x:Name="ClearSelectedLabel"
                    Text="Clear selected items"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="#0F7B4D"
                    TextDecorations="Underline">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="ClearSelectedLabel_Tapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label
                    x:Name="ClearAllLabel"
                    Text="Clear all items"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="#B42318"
                    TextDecorations="Underline">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="ClearAllLabel_Tapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <Border
                x:Name="TrashButton"
                Grid.Column="1"
                WidthRequest="44"
                HeightRequest="40"
                BackgroundColor="#FFFFFF"
                Stroke="#D9E1E8"
                StrokeThickness="1"
                HorizontalOptions="End"
                VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#22000000" Offset="0,5" Radius="12" Opacity="0.3" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="TrashButton_Tapped" />
                </Border.GestureRecognizers>
                <local:TrashIconView HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>
    </Grid>
</ContentPage>
