<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Memory_Storage.SettingsPage"
    Shell.NavBarIsVisible="False"
    NavigationPage.BarBackgroundColor="#EAF7EF"
    NavigationPage.BarTextColor="#14171A"
    BackgroundColor="#F7F8FA">

    <Grid x:Name="RootGrid" BackgroundColor="#F7F8FA">
        <ScrollView>
            <VerticalStackLayout
                Padding="18,22,18,28"
                MinimumHeightRequest="620"
                VerticalOptions="Center">
                <Border
                    x:Name="SettingsCard"
                    Padding="20"
                    MaximumWidthRequest="560"
                    HorizontalOptions="Fill"
                    BackgroundColor="White"
                    Stroke="#E1E6EC"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="18">
                        <Label
                            x:Name="TitleLabel"
                            Text="Settings"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="#14171A"
                            HorizontalTextAlignment="Start"
                            LineBreakMode="NoWrap" />

                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="LanguageLabel" Text="Language" FontSize="15" TextColor="#3C4653" />
                            <Picker
                                x:Name="LanguagePicker"
                                Title="Choose language"
                                HorizontalOptions="Fill"
                                SelectedIndexChanged="LanguagePicker_SelectedIndexChanged" />
                        </VerticalStackLayout>

                        <Border x:Name="ThemePanel" Padding="14" BackgroundColor="#EAF5EF" Stroke="#D8E9DF" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                <VerticalStackLayout Spacing="2">
                                    <Label x:Name="ThemeTitleLabel" Text="Light mode" FontSize="16" FontAttributes="Bold" TextColor="#14171A" LineBreakMode="TailTruncation" />
                                    <Label x:Name="ThemeSubtitleLabel" Text="Dark mode" FontSize="13" TextColor="#5F6B7A" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="ThemeSwitch" Toggled="ThemeSwitch_Toggled" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
