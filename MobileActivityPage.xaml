<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Memory_Storage"
    x:Class="Memory_Storage.MobileActivityPage"
    NavigationPage.HasNavigationBar="False"
    x:Name="RootPage"
    BackgroundColor="#F7F8FA">

    <Grid x:Name="RootGrid" RowDefinitions="Auto,*" BackgroundColor="#F7F8FA">
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,18,16,28" Spacing="16">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <Button
                        x:Name="BackButton"
                        Text="Back"
                        WidthRequest="84"
                        HeightRequest="42"
                        Padding="10,0"
                        BackgroundColor="#1E8E5A"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        Clicked="BackButton_Clicked" />

                    <HorizontalStackLayout Grid.Column="2" Spacing="8">
                        <Border
                            x:Name="AvatarButton"
                            WidthRequest="44"
                            HeightRequest="42"
                            BackgroundColor="#EAF5EF"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="21" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="AvatarButton_Clicked" />
                            </Border.GestureRecognizers>
                            <Grid>
                                <Image x:Name="AvatarImage" Aspect="AspectFill" IsVisible="False" />
                                <local:AvatarIconView x:Name="AvatarIcon" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border
                            x:Name="SettingsButton"
                            WidthRequest="44"
                            HeightRequest="42"
                            BackgroundColor="#EAF5EF"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="21" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="SettingsButton_Clicked" />
                            </Border.GestureRecognizers>
                            <local:SettingsIconView x:Name="SettingsIcon" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </HorizontalStackLayout>
                </Grid>

                <VerticalStackLayout Spacing="2">
                    <Label x:Name="TitleLabel" Text="Memory Storage" FontSize="31" FontAttributes="Bold" TextColor="#14171A" />
                    <Label x:Name="TodayLabel" FontSize="14" TextColor="#5F6B7A" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button x:Name="LoginButton" Text="Login" HeightRequest="44" BackgroundColor="#1E8E5A" TextColor="White" CornerRadius="12" Clicked="LoginButton_Clicked" />
                    <Button x:Name="RegisterButton" Grid.Column="1" Text="Register" HeightRequest="44" BackgroundColor="#1E8E5A" TextColor="White" CornerRadius="12" Clicked="RegisterButton_Clicked" />
                </Grid>

                <SearchBar
                    x:Name="RecordSearchBar"
                    Placeholder="Search app, project, file, note, or cabinet code"
                    SearchButtonPressed="RecordSearchBar_SearchButtonPressed"
                    TextChanged="RecordSearchBar_TextChanged" />

                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="OpenedProgramsButton" Text="Record opened programs" StyleId="UsedApps" HeightRequest="42" Padding="16,0" Clicked="FeatureButton_Clicked" BackgroundColor="#1E8E5A" TextColor="White" CornerRadius="14" />
                        <Button x:Name="DurationButton" Text="Record activity duration" StyleId="Duration" HeightRequest="42" Padding="16,0" Clicked="FeatureButton_Clicked" BackgroundColor="#EAF5EF" TextColor="#0F7B4D" CornerRadius="14" />
                        <Button x:Name="TimelineButton" Text="Timeline view" StyleId="Timeline" HeightRequest="42" Padding="16,0" Clicked="FeatureButton_Clicked" BackgroundColor="#EAF5EF" TextColor="#0F7B4D" CornerRadius="14" />
                        <Button x:Name="SearchFeatureButton" Text="Search function records" StyleId="Search" HeightRequest="42" Padding="16,0" Clicked="FeatureButton_Clicked" BackgroundColor="#EAF5EF" TextColor="#0F7B4D" CornerRadius="14" />
                    </HorizontalStackLayout>
                </ScrollView>

                <Border
                    x:Name="FeaturePanel"
                    Padding="0"
                    BackgroundColor="White"
                    Stroke="#E1E6EC"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Grid RowDefinitions="Auto,Auto">
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto">
                            <Label x:Name="FeatureTitleLabel" Text="Record opened programs" FontSize="16" FontAttributes="Bold" TextColor="#14171A" VerticalTextAlignment="Center" />
                            <Button
                                x:Name="FeatureExpandButton"
                                Grid.Column="1"
                                Text="⌃"
                                WidthRequest="36"
                                HeightRequest="32"
                                Padding="0"
                                BackgroundColor="#EAF5EF"
                                TextColor="#0F7B4D"
                                FontAttributes="Bold"
                                CornerRadius="16"
                                Clicked="FeatureExpandButton_Clicked" />
                        </Grid>

                        <ScrollView
                            x:Name="FeatureContentScroll"
                            Grid.Row="1"
                            Padding="14,0,14,14"
                            MaximumHeightRequest="190"
                            Orientation="Vertical">
                            <Label x:Name="FeatureContentLabel" FontSize="13" TextColor="#3C4653" />
                        </ScrollView>
                    </Grid>
                </Border>

                <Border
                    x:Name="RecordingToggleCard"
                    Padding="16,14"
                    BackgroundColor="#111816"
                    Stroke="#263A33"
                    StrokeThickness="1.5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#66000000" Offset="0,8" Radius="18" Opacity="0.28" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="9" HorizontalOptions="Center">
                        <Label x:Name="RecordingToggleLabel" FontSize="15" FontAttributes="Bold" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                        <Label x:Name="RecordingToggleStateLabel" Grid.Row="1" Text="Recording ON" FontSize="11" FontAttributes="Bold" TextColor="#6FE0A5" HorizontalOptions="Center" />
                        <Border
                            x:Name="RecordingToggleButton"
                            Grid.Row="2"
                            WidthRequest="78"
                            HeightRequest="36"
                            BackgroundColor="#20C978"
                            StrokeThickness="0"
                            HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="RecordingToggleButton_Tapped" />
                            </Border.GestureRecognizers>
                            <Grid Padding="4">
                                <Border
                                    x:Name="RecordingToggleThumb"
                                    WidthRequest="28"
                                    HeightRequest="28"
                                    BackgroundColor="White"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Center"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <HorizontalStackLayout x:Name="DeleteLinksPanel" Spacing="16" IsVisible="{Binding IsDeleteMode}" VerticalOptions="Center">
                        <Label x:Name="ClearSelectedLabel" Text="Clear selected items" FontSize="13" FontAttributes="Bold" TextColor="#0F7B4D" TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="ClearSelectedLabel_Tapped" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Label x:Name="ClearAllLabel" Text="Clear all items" FontSize="13" FontAttributes="Bold" TextColor="#B42318" TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="ClearAllLabel_Tapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <Border
                        x:Name="TrashButton"
                        Grid.Column="1"
                        WidthRequest="46"
                        HeightRequest="42"
                        BackgroundColor="White"
                        Stroke="#D9E1E8"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="TrashButton_Tapped" />
                        </Border.GestureRecognizers>
                        <local:TrashIconView HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>

                <CollectionView
                    x:Name="RecordCollectionView"
                    ItemsSource="{Binding VisibleRecords}"
                    SelectionMode="Single"
                    SelectionChanged="RecordCollectionView_SelectionChanged">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="20" Spacing="7" HorizontalOptions="Center">
                            <Label x:Name="NoRecordsLabel" Text="No records yet" FontSize="17" TextColor="#3C4653" HorizontalTextAlignment="Center" />
                            <Label x:Name="FreshSessionLabel" Text="This session starts fresh and clears automatically when the app closes." FontSize="13" TextColor="#6B7785" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border HeightRequest="214" Padding="10" BackgroundColor="White" Stroke="#D9E1E8" StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Grid RowDefinitions="Auto,104,Auto" RowSpacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Border Padding="7,5" BackgroundColor="#26343B" StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="6" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding DateBadge}" FontSize="10" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" />
                                        </Border>
                                        <Border Grid.Column="1" Margin="6,0,0,0" WidthRequest="34" HeightRequest="34" BackgroundColor="White" Stroke="#26343B" StrokeThickness="2">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="17" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding CabinetCode}" FontSize="11" FontAttributes="Bold" TextColor="#26343B" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="1">
                                        <Border WidthRequest="92" HeightRequest="98" HorizontalOptions="Center" VerticalOptions="Center" BackgroundColor="#F9FAFB" Stroke="#333740" StrokeThickness="4">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="7" />
                                            </Border.StrokeShape>
                                            <Grid Padding="12" RowDefinitions="*,*,*" RowSpacing="6">
                                                <BoxView HeightRequest="6" WidthRequest="48" Color="#333740" HorizontalOptions="Center" VerticalOptions="Center" />
                                                <BoxView Grid.Row="1" HeightRequest="6" WidthRequest="48" Color="#333740" HorizontalOptions="Center" VerticalOptions="Center" />
                                                <BoxView Grid.Row="2" HeightRequest="6" WidthRequest="48" Color="#333740" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Grid>
                                        </Border>
                                        <Border WidthRequest="62" HeightRequest="68" Margin="78,34,0,0" HorizontalOptions="Center" VerticalOptions="Center" BackgroundColor="White" Stroke="#333740" StrokeThickness="4">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="4" />
                                            </Border.StrokeShape>
                                            <Grid RowDefinitions="16,*" Padding="8">
                                                <BoxView HeightRequest="4" WidthRequest="22" Color="#333740" HorizontalOptions="Start" VerticalOptions="Center" />
                                                <BoxView Grid.Row="1" WidthRequest="4" HeightRequest="28" Color="#333740" HorizontalOptions="Start" VerticalOptions="Center" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Label Grid.Row="2" Text="{Binding FileTitle}" FontSize="13" FontAttributes="Bold" TextColor="#14171A" HorizontalTextAlignment="Center" LineBreakMode="TailTruncation" />

                                    <Border
                                        WidthRequest="22"
                                        HeightRequest="22"
                                        Margin="0,0,-11,-11"
                                        BackgroundColor="Transparent"
                                        Stroke="#1E8E5A"
                                        StrokeThickness="1.5"
                                        HorizontalOptions="End"
                                        VerticalOptions="End"
                                        IsVisible="{Binding Source={x:Reference RootPage}, Path=BindingContext.IsDeleteMode}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="5" />
                                        </Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelectedForDeletion}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#1E8E5A" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="✓" FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Opacity="0">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelectedForDeletion}" Value="True">
                                                    <Setter Property="Opacity" Value="1" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button x:Name="AppUserGuideButton" Text="App User Guide" HeightRequest="46" BackgroundColor="#C9362B" TextColor="White" FontAttributes="Bold" CornerRadius="12" Clicked="AppUserGuideButton_Clicked" />
                    <Button x:Name="PrivacyStatementButton" Grid.Column="1" Text="Privacy Statement" HeightRequest="46" BackgroundColor="#C9362B" TextColor="White" FontAttributes="Bold" CornerRadius="12" Clicked="PrivacyStatementButton_Clicked" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
